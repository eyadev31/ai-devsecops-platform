# Google Gemini API Key
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# Groq API Key (High-performance free alternative)
# Get yours free at: https://console.groq.com/keys
# Recommended model: llama-3.3-70b-versatile
GROQ_API_KEY=your_key_here

# FRED API Key (required for macroeconomic data)
# Get yours free at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_key_here

# TwelveData API Key (required for equities/ETFs/forex data)
# Get yours free at: https://twelvedata.com/pricing (free tier = 800 req/day)
TWELVEDATA_API_KEY=your_key_here

# --- LLM Provider Settings ---
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LOG_LEVEL=INFO
DATA_CACHE_TTL_MINUTES=15

# NewsAPI Key
NEWS_API_KEY=your_key_here